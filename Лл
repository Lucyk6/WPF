<!-- MainWindow.xaml -->
<Window x:Class="CipherApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Шифровка и дешифровка" Height="500" Width="700"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Шифровка и дешифровка текста" FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="5"/>

        <GroupBox Grid.Row="1" Header="Выберите шифр" Margin="5">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="rbCaesar" Content="Шифр Цезаря" GroupName="Cipher" 
                             IsChecked="True" Margin="10"/>
                <RadioButton x:Name="rbAtbash" Content="Шифр Атбаш" GroupName="Cipher" Margin="10"/>
                <RadioButton x:Name="rbVigenere" Content="Шифр Виженера" GroupName="Cipher" Margin="10"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="Исходный текст" Margin="5">
            <TextBox x:Name="txtInput" Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"/>
        </GroupBox>

        <Grid Grid.Row="3" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="btnEncrypt" Content="Зашифровать →" Grid.Column="0" Height="35" 
                    Margin="5" Click="BtnEncrypt_Click" Background="LightGreen"/>
            <Button x:Name="btnDecrypt" Content="← Дешифровать" Grid.Column="2" Height="35" 
                    Margin="5" Click="BtnDecrypt_Click" Background="LightCoral"/>
        </Grid>

        <GroupBox Grid.Row="4" Header="Результат" Margin="5">
            <TextBox x:Name="txtOutput" Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto" IsReadOnly="True"/>
        </GroupBox>

        <GroupBox Grid.Row="5" Header="Дополнительные параметры" Margin="5">
            <StackPanel>
                <Label x:Name="lblKey" Content="Ключ для шифра Виженера:" Visibility="Collapsed"/>
                <TextBox x:Name="txtVigenereKey" Visibility="Collapsed" Height="25" Margin="5,0,5,5"/>
                <Label x:Name="lblShift" Content="Сдвиг для шифра Цезаря (1-25):" Visibility="Visible"/>
                <Slider x:Name="sliderShift" Minimum="1" Maximum="25" Value="3" 
                        Visibility="Visible" Margin="5" TickFrequency="1" IsSnapToTickEnabled="True"/>
                <TextBlock x:Name="txtShiftValue" Text="Сдвиг: 3" Margin="5,0,5,5"/>
            </StackPanel>
        </GroupBox>
    </Grid>
</Window>

// MainWindow.xaml.cs
using System;
using System.Text;
using System.Windows;
using System.Windows.Controls;

namespace CipherApp
{
    public partial class MainWindow : Window
    {
        public MainWindow()
        {
            InitializeComponent();
            sliderShift.ValueChanged += SliderShift_ValueChanged;
        }

        private void SliderShift_ValueChanged(object sender, RoutedPropertyChangedEventArgs<double> e)
        {
            txtShiftValue.Text = $"Сдвиг: {(int)sliderShift.Value}";
        }

        private void BtnEncrypt_Click(object sender, RoutedEventArgs e)
        {
            if (string.IsNullOrWhiteSpace(txtInput.Text))
            {
                MessageBox.Show("Введите текст для шифрования!", "Ошибка", 
                              MessageBoxButton.OK, MessageBoxImage.Warning);
                return;
            }

            string result = "";
            if (rbCaesar.IsChecked == true)
                result = CaesarCipher(txtInput.Text, (int)sliderShift.Value, true);
            else if (rbAtbash.IsChecked == true)
                result = AtbashCipher(txtInput.Text);
            else if (rbVigenere.IsChecked == true)
            {
                if (string.IsNullOrWhiteSpace(txtVigenereKey.Text))
                {
                    MessageBox.Show("Введите ключ для шифра Виженера!", "Ошибка",
                                  MessageBoxButton.OK, MessageBoxImage.Warning);
                    return;
                }
                result = VigenereCipher(txtInput.Text, txtVigenereKey.Text, true);
            }

            txtOutput.Text = result;
        }

        private void BtnDecrypt_Click(object sender, RoutedEventArgs e)
        {
            if (string.IsNullOrWhiteSpace(txtInput.Text))
            {
                MessageBox.Show("Введите текст для дешифровки!", "Ошибка",
                              MessageBoxButton.OK, MessageBoxImage.Warning);
                return;
            }

            string result = "";
            if (rbCaesar.IsChecked == true)
                result = CaesarCipher(txtInput.Text, (int)sliderShift.Value, false);
            else if (rbAtbash.IsChecked == true)
                result = AtbashCipher(txtInput.Text);
            else if (rbVigenere.IsChecked == true)
            {
                if (string.IsNullOrWhiteSpace(txtVigenereKey.Text))
                {
                    MessageBox.Show("Введите ключ для шифра Виженера!", "Ошибка",
                                  MessageBoxButton.OK, MessageBoxImage.Warning);
                    return;
                }
                result = VigenereCipher(txtInput.Text, txtVigenereKey.Text, false);
            }

            txtOutput.Text = result;
        }

        // Шифр Цезаря
        private string CaesarCipher(string text, int shift, bool encrypt)
        {
            if (!encrypt) shift = 26 - shift;
            shift = shift % 26;

            StringBuilder result = new StringBuilder();

            foreach (char c in text)
            {
                if (char.IsLetter(c))
                {
                    char offset = char.IsUpper(c) ? 'A' : 'a';
                    char newChar = (char)(((c - offset + shift) % 26) + offset);
                    result.Append(newChar);
                }
                else
                {
                    result.Append(c);
                }
            }

            return result.ToString();
        }

        // Шифр Атбаш (A-Z зеркально)
        private string AtbashCipher(string text)
        {
            StringBuilder result = new StringBuilder();

            foreach (char c in text)
            {
                if (char.IsLetter(c))
                {
                    if (char.IsUpper(c))
                    {
                        result.Append((char)('Z' - (c - 'A')));
                    }
                    else
                    {
                        result.Append((char)('z' - (c - 'a')));
                    }
                }
                else
                {
                    result.Append(c);
                }
            }

            return result.ToString();
        }

        // Шифр Виженера
        private string VigenereCipher(string text, string key, bool encrypt)
        {
            StringBuilder result = new StringBuilder();
            key = key.ToUpper();
            int keyIndex = 0;

            foreach (char c in text)
            {
                if (char.IsLetter(c))
                {
                    char offset = char.IsUpper(c) ? 'A' : 'a';
                    int keyShift = key[keyIndex % key.Length] - 'A';
                    
                    if (!encrypt) keyShift = -keyShift;
                    
                    int newPos = (c - offset + keyShift) % 26;
                    if (newPos < 0) newPos += 26;
                    
                    result.Append((char)(newPos + offset));
                    keyIndex++;
                }
                else
                {
                    result.Append(c);
                }
            }

            return result.ToString();
        }

        private void rbCaesar_Checked(object sender, RoutedEventArgs e)
        {
            lblKey.Visibility = Visibility.Collapsed;
            txtVigenereKey.Visibility = Visibility.Collapsed;
            lblShift.Visibility = Visibility.Visible;
            sliderShift.Visibility = Visibility.Visible;
            txtShiftValue.Visibility = Visibility.Visible;
        }

        private void rbAtbash_Checked(object sender, RoutedEventArgs e)
        {
            lblKey.Visibility = Visibility.Collapsed;
            txtVigenereKey.Visibility = Visibility.Collapsed;
            lblShift.Visibility = Visibility.Collapsed;
            sliderShift.Visibility = Visibility.Collapsed;
            txtShiftValue.Visibility = Visibility.Collapsed;
        }

        private void rbVigenere_Checked(object sender, RoutedEventArgs e)
        {
            lblKey.Visibility = Visibility.Visible;
            txtVigenereKey.Visibility = Visibility.Visible;
            lblShift.Visibility = Visibility.Collapsed;
            sliderShift.Visibility = Visibility.Collapsed;
            txtShiftValue.Visibility = Visibility.Collapsed;
        }
    }
}
